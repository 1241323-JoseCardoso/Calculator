@startuml
skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam shadowing false

skinparam class {
    BackgroundColor<<Aggregate Root>> #E3F2FD
    BorderColor<<Aggregate Root>> #1565C0
    FontColor<<Aggregate Root>> #1565C0
    HeaderBackgroundColor<<Aggregate Root>> #BBDEFB

    BackgroundColor<<Entity>> #FFF8E1
    BorderColor<<Entity>> #F57F17
    FontColor<<Entity>> #F57F17
    HeaderBackgroundColor<<Entity>> #FFE082

    BackgroundColor<<Value Object>> #F1F8E9
    BorderColor<<Value Object>> #558B2F
    FontColor<<Value Object>> #558B2F
    HeaderBackgroundColor<<Value Object>> #DCEDC8
}

skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #BDBDBD
    BorderStyle dashed
    FontSize 14
}


skinparam ArrowColor #444441

package "Airport Aggregate" <<Frame>> {

    class Airport <<Aggregate Root>> {
        - name : String
        - town : String
        - country : Country
        - airControlAreaCode : AirControlAreaCode
        - iataCode : IataCode
        - icaoCode : IcaoCode
        - coordinates: Coordinates
        - elevation: double
    }

    class Country <<Value Object>>{
        - isoCode : IsoCode
        - name : String
    }

    class Coordinates <<Value Object>>{
        - latitude : double
        - longitude : double
    }

    class IsoCode <<Value Object>>{
        - code : String
    }

    class IataCode <<Value Object>>{
        - code : String
    }

    class IcaoCode <<Value Object>>{
       - code : String
     }

    Coordinates --* Airport
    Airport *-- IataCode
    Airport *-- IcaoCode
    Airport *-- Country
    Country *-- IsoCode
}
@enduml